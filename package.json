{
  "name": "calorie-flow",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "build:cloudflare": "opennextjs-cloudflare build",
    "build:sites": "node scripts/prepare-sites.mjs",
    "preview:cloudflare": "opennextjs-cloudflare preview",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "docs:list": "rg --files docs -g '*.md' | xargs rg -l 'read_when'",
    "prepare": "husky"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "@zxing/browser": "0.2.1",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.20.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "typescript": "^5.9.3",
    "vitest": "4.1.10",
    "wrangler": "4.112.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'npm run typecheck'"
    ]
  }
}
